<mujoco model="payload_box">
  <!--
    Identification payload, attached to the end effector via MjSpec.attach().
    Loaded standalone by build_spec() and attached with prefix "payload_", so
    box_mount becomes payload_box_mount after attachment. Colors are set via
    geom rgba to keep the fragment self-contained.
  -->
  <worldbody>
    <body name="box_mount" pos="0 0 0">
      <body name="blue_body" pos="0 0 0">
        <geom name="box_blue" type="box" pos="0 0 0.1" size="0.05 0.05 0.1"
          rgba="0.2 0.35 0.85 1" density="200"/>
        <body name="red_body" pos="0 0 0.2">
          <geom name="box_red" type="box" pos="0 0 0.05" size="0.05 0.15 0.05"
            rgba="0.85 0.2 0.2 1" density="200"/>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
