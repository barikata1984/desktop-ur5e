<mujoco model="push">
  <!--
    Composed 2D pusher-slider scene: UR5e + Robotiq 2F-85 pushing a slider
    on the work surface. Composed from shared environment, robot, and object
    fragments via <include>.
  -->
  <compiler angle="radian" autolimits="true"/>

  <include file="../common/environment.xml"/>
  <include file="../common/robots/ur5e_gripper.xml"/>
  <include file="../objects/slider.xml"/>

  <worldbody>
    <!-- Tracking camera on the slider -->
    <camera name="slider_track" mode="targetbodycom" target="slider"
      pos="0.35 0.5 0.65" fovy="50"/>
  </worldbody>

  <contact>
    <!-- Robot base sits on table — exclude to prevent jitter -->
    <exclude body1="base" body2="table"/>
    <!-- Wrist/gripper collision capsules extend beyond the visual mesh at
         table height; exclude so the arm can work at table-surface level. -->
    <exclude body1="wrist_1_link" body2="table"/>
    <exclude body1="wrist_2_link" body2="table"/>
    <exclude body1="wrist_3_link" body2="table"/>
    <exclude body1="gripper_mount" body2="table"/>
    <exclude body1="base_mount" body2="table"/>
    <exclude body1="gripper_base" body2="table"/>
    <exclude body1="right_driver" body2="table"/>
    <exclude body1="right_coupler" body2="table"/>
    <exclude body1="right_spring_link" body2="table"/>
    <exclude body1="right_follower" body2="table"/>
    <exclude body1="right_pad" body2="table"/>
    <exclude body1="left_driver" body2="table"/>
    <exclude body1="left_coupler" body2="table"/>
    <exclude body1="left_spring_link" body2="table"/>
    <exclude body1="left_follower" body2="table"/>
    <exclude body1="left_pad" body2="table"/>

    <!-- Same wrist/gripper exclusions vs the work surface (arm operates above it) -->
    <exclude body1="wrist_1_link" body2="work_surface"/>
    <exclude body1="wrist_2_link" body2="work_surface"/>
    <exclude body1="wrist_3_link" body2="work_surface"/>
    <exclude body1="gripper_mount" body2="work_surface"/>
    <exclude body1="base_mount" body2="work_surface"/>
    <exclude body1="gripper_base" body2="work_surface"/>
    <exclude body1="right_driver" body2="work_surface"/>
    <exclude body1="right_coupler" body2="work_surface"/>
    <exclude body1="right_spring_link" body2="work_surface"/>
    <exclude body1="right_follower" body2="work_surface"/>
    <exclude body1="right_pad" body2="work_surface"/>
    <exclude body1="left_driver" body2="work_surface"/>
    <exclude body1="left_coupler" body2="work_surface"/>
    <exclude body1="left_spring_link" body2="work_surface"/>
    <exclude body1="left_follower" body2="work_surface"/>
    <exclude body1="left_pad" body2="work_surface"/>

    <!-- Slider-table: mu=0.35, condim=4 for torsional friction (Hogan 2016) -->
    <pair geom1="slider_geom" geom2="table_surface" condim="4"
      friction="0.35 0.35 0.005 0.001 0.001"
      solref="0.02 1" solimp="0.9 0.95 0.001 0.5 2"/>

    <!-- Slider-work surface: same friction model as the table -->
    <pair geom1="slider_geom" geom2="work_surface_geom" condim="4"
      friction="0.35 0.35 0.005 0.001 0.001"
      solref="0.02 1" solimp="0.9 0.95 0.001 0.5 2"/>

    <!-- Gripper pad vs slider: mu=0.3, condim=4 (Hogan 2016 pusher-slider) -->
    <pair geom1="right_pad1" geom2="slider_geom" condim="4"
      friction="0.3 0.3 0.005 0.001 0.001"
      solref="0.004 1" solimp="0.95 0.99 0.001 0.5 2"/>
    <pair geom1="right_pad2" geom2="slider_geom" condim="4"
      friction="0.3 0.3 0.005 0.001 0.001"
      solref="0.004 1" solimp="0.95 0.99 0.001 0.5 2"/>
    <pair geom1="left_pad1" geom2="slider_geom" condim="4"
      friction="0.3 0.3 0.005 0.001 0.001"
      solref="0.004 1" solimp="0.95 0.99 0.001 0.5 2"/>
    <pair geom1="left_pad2" geom2="slider_geom" condim="4"
      friction="0.3 0.3 0.005 0.001 0.001"
      solref="0.004 1" solimp="0.95 0.99 0.001 0.5 2"/>
  </contact>

  <keyframe>
    <!-- qpos: 6 arm + 8 gripper (closed) + 7 slider_freejoint = 21 values
         ctrl: 6 arm + 1 gripper (255=closed) = 7 values -->
    <key name="ready"
      qpos="1.1803 -1.6653 2.4917 -2.3972 -1.5708 -0.3905
             0.782171 0.000500 0.780958 -0.757842 0.782169 0.000503 0.780896 -0.758075
             0 0.5 0.342 1 0 0 0"
      ctrl="1.1803 -1.6708 2.4842 -2.4020 -1.5708 -0.3905 255"/>
  </keyframe>
</mujoco>
